# Summarize the turn with a model call (true) or just show the static message
context_aware=true
summarize_model=claude-haiku-4-5-20251001

# Notification icon. Empty = alerter's default. Example:
# icon=/Applications/Claude.app/Contents/Resources/electron.icns
icon=

# App opened when you click the notification. Empty = clicking does nothing.
# Example: action_app="Visual Studio Code"
action_app=

# Seconds before the notification auto-dismisses. Empty = it waits until you
# click or dismiss it (and keeps the click-to-open window open that whole time).
alerter_timeout=
