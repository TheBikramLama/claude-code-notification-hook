{
  "PermissionRequest": {
    "hooks": [
      {
        "type": "command",
        "command": "~/.claude/hooks/notify.sh --title 'Claude needs permission' --message 'Requesting tool access' --sound 'Funk' --context_aware false"
      }
    ]
  },
  "Stop": {
    "hooks": [
      {
        "type": "command",
        "timeout": 25,
        "command": "~/.claude/hooks/notify.sh --title 'Claude finished' --message 'Response ready' --sounde 'Glass'"
      }
    ]
  },
  "StopFailure": {
    "hooks": [
      {
        "type": "command",
        "timeout": 25,
        "command": "~/.claude/hooks/notify.sh --title 'Claude error' --message 'Turn ended with API error' --sound 'Basso' --context_aware false"
      }
    ]
  },
  "PostCompact": {
    "hooks": [
      {
        "type": "command",
        "timeout": 25,
        "command": "~/.claude/hooks/notify.sh --title 'Claude compact' --message 'Context trimmed' --sound 'Glass' --context_aware false"
      }
    ]
  }
}